{
  "name": "speedtest-exporter",
  "version": "1.0.0",
  "description": "Bun-powered Prometheus exporter for speedtest metrics, using Cloudflare network.",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "bun test",
    "ci": "bun run lint && bun run format:check && bun run typecheck && bun run test"
  },
  "dependencies": {
    "prom-client": "^15.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
